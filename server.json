{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.agenticempire/axint",
  "title": "Axint",
  "description": "Compiler and repair loop for agent-built Apple apps: App Intents, SwiftUI, WidgetKit.",
  "repository": {
    "url": "https://github.com/agenticempire/axint",
    "source": "github"
  },
  "homepage": "https://axint.ai",
  "documentation": "https://docs.axint.ai",
  "version": "0.4.16",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.axint.ai/mcp"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@axint/compiler",
      "version": "0.4.16",
      "transport": {
        "type": "stdio"
      }
    },
    {
      "registryType": "pypi",
      "identifier": "axint",
      "version": "0.4.16",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "capabilities": {
    "tools": 33,
    "prompts": 5
  }
}
