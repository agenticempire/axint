// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Widget Compiler > snapshot: step counter full pipeline output 1`] = `
"// StepCounterWidget.swift
// Axint compiler output. Edit freely; regenerate from the source definition when useful.

import WidgetKit
import SwiftUI

struct StepCounterEntry: TimelineEntry {
    let date: Date
    let steps: Int = 0
    let goal: Int = 10000
    let lastUpdated: Date
}

struct StepCounterProvider: TimelineProvider {
    func placeholder(in context: Context) -> StepCounterEntry {
        StepCounterEntry(date: Date(), steps: 0, goal: 10000, lastUpdated: Date())
    }

    func getSnapshot(in context: Context, completion: @escaping (StepCounterEntry) -> Void) {
        let entry = StepCounterEntry(date: Date(), steps: 0, goal: 10000, lastUpdated: Date())
        completion(entry)
    }

    func getTimeline(in context: Context, completion: @escaping (Timeline<StepCounterEntry>) -> Void) {
        let entry = StepCounterEntry(date: Date(), steps: 0, goal: 10000, lastUpdated: Date())
        let timeline = Timeline(entries: [entry], policy: .after(Calendar.current.date(byAdding: .hour, value: 1, to: Date())!))
        completion(timeline)
    }
}

struct StepCounterEntryView: View {
    var entry: StepCounterProvider.Entry

    var body: some View {
        VStack(spacing: 4) {
            Text("(steps)")
            Text("of (goal) steps")
        }
    }
}

struct StepCounterWidget: Widget {
    let kind: String = "StepCounter"

    var body: some WidgetConfiguration {
        StaticConfiguration(
            kind: kind,
            provider: StepCounterProvider()
        ) { entry in
            StepCounterEntryView(entry: entry)
        }
        .configurationDisplayName("Step Counter")
        .description("Shows your daily step count")
        .supportedFamilies([.systemSmall, .systemMedium])
    }
}

#Preview(as: .systemSmall) {
    StepCounterWidget()
} timeline: {
    StepCounterEntry(date: Date(), steps: 0, goal: 10000, lastUpdated: Date())
}
"
`;
